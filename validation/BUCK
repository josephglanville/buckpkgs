_PROJECTION_MAKEFILE_CONTENT = [
    "all:",
    "\t:",
    "install:",
    "\tmkdir -p \"$(DESTDIR)$(PREFIX)/bin\" \"$(DESTDIR)$(PREFIX)/lib/pkgconfig\" \"$(DESTDIR)$(PREFIX)/include\" \"$(DESTDIR)$(PREFIX)/share/doc/contract\"",
    "\tprintf compiler > \"$(DESTDIR)$(PREFIX)/bin/contract-cc\"",
    "\tprintf runtime > \"$(DESTDIR)$(PREFIX)/lib/libcontract.so.1\"",
    "\tprintf dependent-runtime > \"$(DESTDIR)$(PREFIX)/lib/libdependent.so.1\"",
    "\tprintf header > \"$(DESTDIR)$(PREFIX)/include/contract.h\"",
    "\tprintf 'prefix=%s\\nlibdir=$${prefix}/lib\\nincludedir=$${prefix}/include\\nName: contract\\n' \"$(PREFIX)\" > \"$(DESTDIR)$(PREFIX)/lib/pkgconfig/contract.pc\"",
    "\tprintf omitted > \"$(DESTDIR)$(PREFIX)/share/doc/contract/README\"",
]

write_file(
    name = "projection_makefile",
    out = "Makefile",
    content = _PROJECTION_MAKEFILE_CONTENT,
)

filegroup(
    name = "projection_source_tree",
    srcs = {
        "Makefile": ":projection_makefile",
    },
    copy = True,
)

_PROJECTION_SOURCE = pkgs_source(
    dep = ":projection_source_tree",
    digests = ["sha256:" + sha256("\n".join(["Makefile"] + _PROJECTION_MAKEFILE_CONTENT))],
)

pkgs_make_install_package(
    name = "projected_contract_lib",
    package_name = "projected-contract",
    version = "0",
    sources = [_PROJECTION_SOURCE],
    output = "lib",
    output_paths = ["lib/libcontract.so.1"],
    split_outputs = {
        "dev": [
            "include",
            "lib/pkgconfig",
        ],
        "dependent_lib": ["lib/libdependent.so.1"],
        "bin": ["bin/contract-cc"],
    },
    split_pkg_config_paths = {
        "dev": ["lib/pkgconfig"],
    },
    split_reference_outputs = {
        "dev": [
            "lib",
            "dependent_lib",
        ],
    },
    split_reference_paths = {
        "dev": {
            "lib/libcontract.so": "lib/libcontract.so.1",
        },
    },
    split_reference_output_paths = {
        "dev": {
            "lib/libdependent.so": ("dependent_lib", "lib/libdependent.so.1"),
        },
    },
    split_runtime_outputs = {
        "dependent_lib": ["lib"],
        "bin": [
            "lib",
            "dependent_lib",
        ],
    },
    native_build_inputs = [
        "//shells/bash:bin",
        "//development/tools/build-managers/gnumake:bin",
        "//tools/misc/coreutils:bin",
    ],
)

