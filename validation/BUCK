_ELF_RUNTIME_MAKEFILE_CONTENT = [
    "all:",
    "\tcc -g -fdebug-prefix-map=$(CURDIR)=/pkgs/store/dddddddddddddddddddddddddddddddd-undeclared-debug runtime_contract.c -o runtime_contract",
    "install:",
    "\tmkdir -p \"$(DESTDIR)$(PREFIX)/bin\"",
    "\tcp runtime_contract \"$(DESTDIR)$(PREFIX)/bin/runtime_contract\"",
]

_ELF_RUNTIME_C_CONTENT = [
    "int main(void) { return 0; }",
]

_ELF_CXX_RUNTIME_MAKEFILE_CONTENT = [
    "all:",
    "\tc++ runtime_contract.cc -o runtime_contract",
    "install:",
    "\tmkdir -p \"$(DESTDIR)$(PREFIX)/bin\"",
    "\tcp runtime_contract \"$(DESTDIR)$(PREFIX)/bin/runtime_contract\"",
]

_ELF_CXX_RUNTIME_CONTENT = [
    "#include <string>",
    "int main(void) {",
    "    const std::string value = \"runtime\";",
    "    return value.size() == 7 ? 0 : 1;",
    "}",
]

write_file(
    name = "elf_runtime_makefile",
    out = "Makefile",
    content = _ELF_RUNTIME_MAKEFILE_CONTENT,
)

write_file(
    name = "elf_runtime_c",
    out = "runtime_contract.c",
    content = _ELF_RUNTIME_C_CONTENT,
)

write_file(
    name = "elf_cxx_runtime_makefile",
    out = "Makefile",
    content = _ELF_CXX_RUNTIME_MAKEFILE_CONTENT,
)

write_file(
    name = "elf_cxx_runtime_source",
    out = "runtime_contract.cc",
    content = _ELF_CXX_RUNTIME_CONTENT,
)

filegroup(
    name = "elf_runtime_source_tree",
    srcs = {
        "Makefile": ":elf_runtime_makefile",
        "runtime_contract.c": ":elf_runtime_c",
    },
    copy = True,
)

filegroup(
    name = "elf_cxx_runtime_source_tree",
    srcs = {
        "Makefile": ":elf_cxx_runtime_makefile",
        "runtime_contract.cc": ":elf_cxx_runtime_source",
    },
    copy = True,
)

_ELF_RUNTIME_SOURCE = pkgs_source(
    dep = ":elf_runtime_source_tree",
    digests = [
        "sha256:" + sha256("\n".join(["Makefile"] + _ELF_RUNTIME_MAKEFILE_CONTENT)),
        "sha256:" + sha256("\n".join(["runtime_contract.c"] + _ELF_RUNTIME_C_CONTENT)),
    ],
)

_ELF_CXX_RUNTIME_SOURCE = pkgs_source(
