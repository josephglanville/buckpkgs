_NATIVE_TOOLS = [
    "//shells/bash:bin",
    "//development/tools/build-managers/gnumake:bin",
    "//development/tools/misc/binutils:bin",
    "//development/compilers/gcc:bin",
    "//tools/misc/coreutils:bin",
    "//tools/misc/findutils:bin",
    "//tools/text/gawk:bin",
    "//tools/text/gnugrep:bin",
    "//tools/text/gnupatch:bin",
    "//tools/text/gnused:bin",
]

pkgs_configure_make_install_package(
    name = "lib",
    package_name = "readline",
    version = "8.3p3",
    output = "lib",
    sources = [_SOURCE],
    configure_args = [
        "--enable-shared",
        "--with-curses",
    ],
    configure_env = [
        "CC=cc",
        "AR=ar",
        "RANLIB=ranlib",
    ],
    patches = [
        _LINK_AGAINST_NCURSES_PATCH,
        _NO_ARCH_ONLY_PATCH,
        _PATCH_001,
        _PATCH_002,
        _PATCH_003,
    ],
    patch_strip = 0,
    output_paths = ["lib"],
    split_outputs = {
        "dev": [
            "include",
            "lib/libhistory.a",
            "lib/libreadline.a",
            "lib/pkgconfig",
        ],
    },
    split_pkg_config_paths = {
        "dev": ["lib/pkgconfig"],
    },
    native_build_inputs = _NATIVE_TOOLS,
    build_inputs = ["//development/libraries/ncurses:dev"],
    link_inputs = ["//development/libraries/ncurses:lib"],
    runtime_inputs = [
        "//development/libraries/glibc:out",
    ],
    visibility = ["PUBLIC"],
)

pkgs_package_output(
    name = "dev",
    package = ":lib",
    output = "dev",
    visibility = ["PUBLIC"],
)
