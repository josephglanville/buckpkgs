    sha256 = "fe5383204467828cd495ee8d1d3c037a7eba1389c22bc6a041f627976f9061cc",
    strip_prefix = "readline-8.3",
    urls = ["https://ftp.gnu.org/gnu/readline/readline-8.3.tar.gz"],
)

_LINK_AGAINST_NCURSES_PATCH = pkgs_export_patch(
