    src = "patches/0002-no-arch_only.patch",
    sha256 = "d3c87f50ca515d0c2ea4789e4378b1991ec5b92b0d68230891e3b8bf72598a3a",
)

_PATCH_001 = pkgs_export_patch(
    name = "patch_001",
    src = "patches/readline83-001.patch",
