load("//rules:pkgs.bzl", "pkgs_configure_make_install_package", "pkgs_http_archive_source", "pkgs_package_output")

_SOURCE = pkgs_http_archive_source(
    name = "source",
    sha256 = "cd05c9589b9f86ecf044c10a2269822bc9eb001eced2582cfffd658b0a50c243",
    strip_prefix = "pkgconf-2.5.1",
    urls = ["https://distfiles.ariadne.space/pkgconf/pkgconf-2.5.1.tar.xz"],
)

_NATIVE_TOOLS = [
    "//shells/bash:bin",
    "//development/tools/build-managers/gnumake:bin",
    "//development/tools/misc/binutils:bin",
    "//development/compilers/gcc:bin",
    "//tools/misc/coreutils:bin",
    "//tools/misc/findutils:bin",
    "//tools/text/gawk:bin",
    "//tools/text/gnugrep:bin",
    "//tools/text/gnused:bin",
]

pkgs_configure_make_install_package(
    name = "bin",
    package_name = "pkgconf",
    version = "2.5.1",
    output = "bin",
    sources = [_SOURCE],
    configure_args = [
        "--disable-shared",
        "--enable-static",
    ],
    configure_env = [
        "CC=cc",
        "AR=ar",
        "RANLIB=ranlib",
    ],
    symlinks = {
        "bin/pkg-config": "pkgconf",
    },
    output_paths = [
        "bin",
        "share/aclocal",
    ],
    split_outputs = {
        # This realization intentionally emits only libpkgconf.a.  Publish
        # its consumable library API as a static interface, not as dynamic dev.
        "static": [
            "include",
            "lib",
        ],
    },
    split_pkg_config_paths = {
        "static": ["lib/pkgconfig"],
    },
    # libpkgconf records pkgconf's configured default metadata search prefix.
    split_reference_outputs = {
        "static": ["bin"],
    },
    relocate_split_metadata_prefix = True,
    native_build_inputs = _NATIVE_TOOLS,
    runtime_inputs = [
        "//development/libraries/glibc:lib",
    ],
    visibility = ["PUBLIC"],
)

pkgs_package_output(
    name = "static",
    package = ":bin",
    output = "static",
    visibility = ["PUBLIC"],
)
