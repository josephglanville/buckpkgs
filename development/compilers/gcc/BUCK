_DEBUG_PREFIX_MAP_ENV_PATCH = pkgs_export_patch(
    name = "debug_prefix_map_env_patch",
    src = "patches/0001-debug-prefix-map-from-env.patch",
    sha256 = "a9b93550bf0b10e366c8a4ee6e6defcb8f84521c08bd0c03e6587ad781818d57",
)

pkgs_configure_make_install_package(
    name = "out_stage0",
    package_name = "gcc",
    version = "15.2.0",
    sources = [_SOURCE],
    out_of_source = True,
    configure_args = [
        "--disable-bootstrap",
        "--disable-multilib",
        "--disable-nls",
        "--disable-libsanitizer",
        "--disable-libssp",
        "--disable-libvtv",
        "--disable-libitm",
        "--disable-libquadmath",
        "--disable-libgomp",
        "--disable-libatomic",
        "--disable-libstdcxx-pch",
        "--without-isl",
        "--without-included-gettext",
        "--with-zstd=no",
        "--enable-languages=c,c++",
        pkgs_store_path("--with-gmp=", "//development/libraries/gmp:out_stage0"),
        pkgs_store_path("--with-mpfr=", "//development/libraries/mpfr:out_stage0"),
        pkgs_store_path("--with-mpc=", "//development/libraries/libmpc:out_stage0"),
    ],
    configure_env = [
        "CC=cc",
        "CXX=c++",
        "AR=ar",
        "AS=as",
        "LD=ld",
        "RANLIB=ranlib",
        "CXXFLAGS=-fno-char8_t",
        "DEBUG_PREFIX_CFLAGS_FOR_TARGET=-ffile-prefix-map=@PKGS_WORK_DIR@=. -fdebug-prefix-map=@PKGS_WORK_DIR@=.",
    ],
    make_args = ["MAKEINFO=true"],
    patches = [_DEBUG_PREFIX_MAP_ENV_PATCH],
    native_build_inputs = _STAGE0_NATIVE_TOOLS,
    build_inputs = _MATH_STAGE0,
    visibility = BOOTSTRAP_PRODUCER_VISIBILITY,
)

pkgs_seed_free(
    name = "out_stage0_seed_free",
    packages = [":out_stage0"],
    forbidden = ["//bootstrap/foreign_seed:gcc"],
    visibility = BOOTSTRAP_PRODUCER_VISIBILITY,
)

pkgs_configure_make_install_package(
    name = "out_stage1",
    package_name = "gcc",
    version = "15.2.0",
    sources = [_SOURCE],
    out_of_source = True,
    configure_args = [
        "--disable-bootstrap",
        "--disable-multilib",
        "--disable-nls",
        "--disable-libsanitizer",
        "--disable-libssp",
        "--disable-libvtv",
        "--disable-libitm",
        "--disable-libquadmath",
        "--disable-libgomp",
        "--disable-libatomic",
        "--disable-libstdcxx-pch",
        "--disable-default-pie",
        "--without-isl",
        "--without-included-gettext",
        "--with-zstd=no",
        "--enable-languages=c,c++",
        "--with-native-system-header-dir=/include",
        pkgs_store_path("--with-gmp=", "//development/libraries/gmp:out_stage0"),
        pkgs_store_path("--with-mpfr=", "//development/libraries/mpfr:out_stage0"),
        pkgs_store_path("--with-mpc=", "//development/libraries/libmpc:out_stage0"),
        pkgs_store_path("--with-build-sysroot=", "//development/libraries/glibc:dev_stage1"),
    ],
    configure_env = [
        "CC=gcc",
        "CXX=g++",
        "AR=ar",
        "AS=as",
        "LD=ld",
        "RANLIB=ranlib",
        "CXXFLAGS=-fno-char8_t",
        "DEBUG_PREFIX_CFLAGS_FOR_TARGET=-ffile-prefix-map=@PKGS_WORK_DIR@=. -fdebug-prefix-map=@PKGS_WORK_DIR@=.",
        pkgs_store_path("CPPFLAGS_FOR_TARGET=-idirafter ", "//os-specific/linux/kernel-headers:dev_final", "/include"),
        pkgs_store_path("CFLAGS_FOR_TARGET=-idirafter ", "//os-specific/linux/kernel-headers:dev_final", "/include"),
        pkgs_store_path("CXXFLAGS_FOR_TARGET=-fno-char8_t -idirafter ", "//os-specific/linux/kernel-headers:dev_final", "/include"),
        pkgs_store_path("FLAGS_FOR_TARGET=-B", "//development/libraries/glibc:dev_stage1", "/lib"),
        pkgs_store_path_join("LDFLAGS=-Wl,-rpath,", _MATH_STAGE0, "/lib -Wl,-rpath,", "/lib"),
    ],
    make_args = ["MAKEINFO=true"],
    patches = [_DEBUG_PREFIX_MAP_ENV_PATCH],
    native_build_inputs = _STAGE1_NATIVE_TOOLS,
    build_inputs = _MATH_STAGE0 + [
        "//development/libraries/glibc:dev_stage1",
        "//os-specific/linux/kernel-headers:dev_final",
    ],
    runtime_inputs = _MATH_STAGE0 + [
        "//development/libraries/glibc:lib_stage1",
    ],
    visibility = BOOTSTRAP_PRODUCER_VISIBILITY,
)

