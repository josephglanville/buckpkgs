# GCC's own host programs link their C++ support statically. Avoid preserving
# the stage compiler as an unused RUNPATH in the final compiler executables.
pkgs_cc_wrapper_package(
    name = "bin_stage1_for_final_gcc",
    package_name = "gcc-wrapper-build-only",
    version = "15.2.0",
    cc = ":out_stage1",
    bintools = "//development/tools/misc/binutils:bin_stage0_wrapped",
    headers = "//os-specific/linux/kernel-headers:dev_final",
    libc = "//development/libraries/glibc:lib_stage1",
    libc_runtime = "//development/libraries/glibc:lib_stage1",
    libc_dev = "//development/libraries/glibc:dev_stage1",
    shell = "//shells/bash:bin_stage2",
    suppress_cxx_runtime_rpaths = True,
    reference_inputs = [
        ":out_stage1",
        "//development/tools/misc/binutils:bin_stage0_wrapped",
        "//os-specific/linux/kernel-headers:dev_final",
        "//development/libraries/glibc:lib_stage1",
        "//development/libraries/glibc:dev_stage1",
        "//shells/bash:bin_stage2",
    ],
    runtime_inputs = [
        ":out_stage1",
        "//shells/bash:bin_stage2",
    ],
    tool_inputs = [
        ":out_stage1",
        "//development/tools/misc/binutils:bin_stage0_wrapped",
        "//os-specific/linux/kernel-headers:dev_final",
        "//development/libraries/glibc:lib_stage1",
        "//development/libraries/glibc:dev_stage1",
        "//shells/bash:bin_stage2",
    ],
    visibility = BOOTSTRAP_PRODUCER_VISIBILITY,
)

pkgs_configure_make_install_package(
    name = "compiler_final",
    package_name = "gcc",
    version = "15.2.0",
    output = "bin",
    sources = [_SOURCE],
    out_of_source = True,
    configure_args = [
        "--disable-bootstrap",
        "--disable-multilib",
        "--disable-nls",
        "--disable-libsanitizer",
        "--disable-libssp",
        "--disable-libvtv",
        "--disable-libitm",
        "--disable-libquadmath",
        "--disable-libgomp",
        "--disable-libatomic",
        "--disable-libcc1",
        "--disable-libstdcxx-pch",
        "--disable-default-pie",
        "--without-isl",
        "--without-included-gettext",
        "--with-zstd=no",
        "--enable-languages=c,c++",
        "--with-native-system-header-dir=/include",
        pkgs_store_path("--with-gmp=", "//development/libraries/gmp:dev_final"),
        pkgs_store_path("--with-mpfr=", "//development/libraries/mpfr:dev_final"),
        pkgs_store_path("--with-mpc=", "//development/libraries/libmpc:dev_final"),
        pkgs_store_path("--with-build-sysroot=", "//development/libraries/glibc:dev_stage1"),
    ],
    configure_env = [
        "CC=gcc",
        "CXX=g++",
        "AR=ar",
        "AS=as",
        "LD=ld",
        "RANLIB=ranlib",
        pkgs_store_path("CXXFLAGS=-fno-char8_t -ffile-prefix-map=", ":out_stage1", "=/build/gcc-stage1"),
        pkgs_store_path("LD_LIBRARY_PATH=", ":out_stage1", "/lib64"),
        "DEBUG_PREFIX_CFLAGS_FOR_TARGET=-ffile-prefix-map=@PKGS_WORK_DIR@=. -fdebug-prefix-map=@PKGS_WORK_DIR@=.",
        pkgs_store_path("CPPFLAGS_FOR_TARGET=-idirafter ", "//os-specific/linux/kernel-headers:dev_final", "/include"),
        pkgs_store_path("CFLAGS_FOR_TARGET=-idirafter ", "//os-specific/linux/kernel-headers:dev_final", "/include"),
        pkgs_store_path("CXXFLAGS_FOR_TARGET=-fno-char8_t -idirafter ", "//os-specific/linux/kernel-headers:dev_final", "/include"),
        pkgs_store_path("FLAGS_FOR_TARGET=-B", "//development/libraries/glibc:dev_stage1", "/lib"),
        pkgs_store_path_join("LDFLAGS=-Wl,-rpath,", _MATH_LIBS_FINAL, "/lib -Wl,-rpath,", "/lib"),
    ],
    make_args = ["MAKEINFO=true"],
    patches = [_DEBUG_PREFIX_MAP_ENV_PATCH],
    output_paths = [
        "bin",
        _PRIVATE_RUNTIME_DIR + "/crtbegin.o",
        _PRIVATE_RUNTIME_DIR + "/crtbeginS.o",
        _PRIVATE_RUNTIME_DIR + "/crtbeginT.o",
        _PRIVATE_RUNTIME_DIR + "/crtend.o",
        _PRIVATE_RUNTIME_DIR + "/crtendS.o",
        _PRIVATE_RUNTIME_DIR + "/crtfastmath.o",
        _PRIVATE_RUNTIME_DIR + "/crtprec32.o",
        _PRIVATE_RUNTIME_DIR + "/crtprec64.o",
        _PRIVATE_RUNTIME_DIR + "/crtprec80.o",
        _PRIVATE_RUNTIME_DIR + "/include",
        _PRIVATE_RUNTIME_DIR + "/include-fixed",
        _PRIVATE_RUNTIME_DIR + "/libgcc.a",
        _PRIVATE_RUNTIME_DIR + "/libgcc_eh.a",
        _PRIVATE_RUNTIME_DIR + "/libgcov.a",
        _LIBEXEC_RUNTIME_DIR + "/cc1",
        _LIBEXEC_RUNTIME_DIR + "/cc1plus",
        _LIBEXEC_RUNTIME_DIR + "/collect2",
        _LIBEXEC_RUNTIME_DIR + "/g++-mapper-server",
        _LIBEXEC_RUNTIME_DIR + "/liblto_plugin.so",
        _LIBEXEC_RUNTIME_DIR + "/lto-wrapper",
        _LIBEXEC_RUNTIME_DIR + "/lto1",
    ],
    split_outputs = {
        "dev": [
            "include",
            "lib64/libgcc_s.so",
            "lib64/libstdc++.modules.json",
            _PRIVATE_RUNTIME_DIR + "/plugin",
        ],
        "libgcc": ["lib64/libgcc_s.so.1"],
        "libstdcxx": [
            "lib64/libstdc++.so.6",
            "lib64/libstdc++.so.6.0.34",
        ],
    },
    split_reference_output_paths = {
        "dev": {
            "lib64/libgcc_s.so.1": ("libgcc", "lib64/libgcc_s.so.1"),
            "lib64/libstdc++.so": ("libstdcxx", "lib64/libstdc++.so.6.0.34"),
        },
    },
    split_reference_outputs = {
        "dev": [
            # Generated plugin configuration headers record the installed compiler prefix.
            "bin",
            "libgcc",
            "libstdcxx",
        ],
    },
    split_runtime_inputs = {
        "libgcc": ["//development/libraries/glibc:lib_stage1"],
        "libstdcxx": ["//development/libraries/glibc:lib_stage1"],
    },
    split_runtime_outputs = {
        "libstdcxx": ["libgcc"],
    },
    native_build_inputs = _STAGE2_NATIVE_TOOLS,
    build_inputs = _MATH_DEVS_FINAL + [
        "//development/libraries/glibc:dev_stage1",
        "//os-specific/linux/kernel-headers:dev_final",
    ],
    link_interface_inputs = _MATH_DEVS_FINAL,
    link_inputs = _MATH_LIBS_FINAL,
    reference_inputs = _MATH_DEVS_FINAL + [
        "//development/libraries/glibc:dev_stage1",
        "//os-specific/linux/kernel-headers:dev_final",
    ],
    runtime_inputs = _MATH_LIBS_FINAL + [
        "//development/libraries/glibc:lib_stage1",
    ],
    visibility = BOOTSTRAP_PRODUCER_VISIBILITY,
)

