    "//tools/text/gnused:bin_stage0",
]

pkgs_configure_make_install_package(
    name = "bin_stage0",
    package_name = "gnused",
    version = "4.9",
    source = ":source",
    source_digests = ["sha256:6e226b732e1cd739464ad6862bd1a1aba42d7982922da7a53519631d24975181"],
    configure_env = ["CC=cc"],
    native_build_inputs = _SEED,
    visibility = ["PUBLIC"],
)

pkgs_seed_free(
    name = "bin_stage0_seed_free",
    packages = [":bin_stage0"],
    forbidden = _SEED,
)

pkgs_configure_make_install_package(
    name = "bin_final",
    package_name = "gnused",
    version = "4.9",
    source = ":source",
    source_digests = ["sha256:6e226b732e1cd739464ad6862bd1a1aba42d7982922da7a53519631d24975181"],
    configure_env = ["CC=cc"],
    native_build_inputs = _FINAL_NATIVE_TOOLS,
    runtime_inputs = ["//development/libraries/glibc:out_stage1"],
